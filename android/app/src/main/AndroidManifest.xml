<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 通知权限 (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
    <!-- APK 安装权限 -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES"/>
    <!-- 查询所有已安装应用（内置浏览器解析应用链接需要获取目标应用图标和名称） -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES"/>
    <!-- 前台服务权限（后台通知保活） -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC"/>
    <!--
        WebAuthn/PassKey: WebView FOR_BROWSER 模式下 Chromium 会把 origin 传给
        Credential Manager，需要此权限才能通过 setOrigin 检查。
        保护级别为 signature|privileged，普通 app 理论上拿不到，但 Via 等
        WebView-based 浏览器实测声明后可正常使用 —— 具体授予机制可能由
        Android 14+ 的浏览器 role / APP_BROWSER 标签触发。
    -->
    <uses-permission android:name="android.permission.CREDENTIAL_MANAGER_SET_ORIGIN"/>
    <application
        android:label="FluxDO"
        android:name=".FluxdoApplication"
        android:icon="@mipmap/ic_launcher"
        android:networkSecurityConfig="@xml/network_security_config">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <!--
                为 Flutter 工具链 / adb 提供 MAIN+LAUNCHER，使其能发现并启动 .MainActivity。
                添加 data scheme 防止启动器匹配此 filter（launcher intent 无 data → 不匹配），
                实际启动器入口由 activity-alias 提供。
            -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
                <data android:scheme="fluxdo-launch" />
            </intent-filter>
            <!-- Deep Links for linux.do - 话题链接 -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" android:host="linux.do" android:pathPrefix="/t/" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="http" android:host="linux.do" android:pathPrefix="/t/" />
            </intent-filter>
            <!-- Deep Links for linux.do - 用户链接 -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" android:host="linux.do" android:pathPrefix="/u/" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="http" android:host="linux.do" android:pathPrefix="/u/" />
            </intent-filter>
            <!-- Deep Links for linux.do - 邮箱链接登录 -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" android:host="linux.do" android:pathPrefix="/session/email-login/" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="http" android:host="linux.do" android:pathPrefix="/session/email-login/" />
            </intent-filter>
            <!-- Custom URL Scheme -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="fluxdo" />
            </intent-filter>
        </activity>
        <!-- 经典图标（默认启动入口） -->
        <activity-alias
            android:name=".DefaultIcon"
            android:enabled="true"
            android:exported="true"
            android:icon="@mipmap/ic_launcher"
            android:targetActivity=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>
        <!-- 现代备选图标（深浅色由 night 资源限定符自动切换） -->
        <activity-alias
            android:name=".ModernIcon"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_modern"
            android:targetActivity=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>
        <!-- 禁用 Firebase 自动采集，由用户手动开启 -->
        <meta-data android:name="firebase_crashlytics_collection_enabled" android:value="false" />
        <meta-data android:name="firebase_analytics_collection_enabled" android:value="false" />
        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
        <!-- FileProvider for OTA update -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.ota_update_provider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/ota_update_filepaths" />
        </provider>
        <!-- ContentProvider for super_clipboard -->
        <provider
            android:name="com.superlist.super_native_extensions.DataProvider"
            android:authorities="${applicationId}.SuperClipboardDataProvider"
            android:exported="true"
            android:grantUriPermissions="true" />
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
        <!-- 查询可处理 VIEW 的应用（浏览器 + 应用链接目标）
             不限定 category/data，使 PackageManager 能看到所有注册了 VIEW 的应用 -->
        <intent>
            <action android:name="android.intent.action.VIEW" />
        </intent>
    </queries>
</manifest>
